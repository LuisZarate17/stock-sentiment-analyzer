# Reddit API credentials
# Register at: https://www.reddit.com/prefs/apps  (choose "script" type)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=StockSentimentAnalyzer/1.0 by YourUsername

# NewsAPI key (optional – RSS is used if this is absent)
# Register at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Flask settings
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-to-a-random-string
